	}
	closeErr := body.Close()
	if readErr != nil {
		readErr = {{ ref "fmt.Errorf" }}("read graphql response: %w", readErr)
	}
	if closeErr != nil {
		closeErr = {{ ref "fmt.Errorf" }}("close graphql response: %w", closeErr)
	}
	return payload, readErr, closeErr
}

